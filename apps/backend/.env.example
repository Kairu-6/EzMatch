# Backend env contract. Set these as platform env vars (Render/Railway secrets).
# Copy to .env for local dev. NEVER commit real values.

# Supabase (service_role key — SECRET, bypasses RLS by design)
SUPABASE_URL=
SUPABASE_API_KEY=

# Morpheus (reconciliation matching + invoice/proof structuring) — API key is SECRET
MORPHEUS_URL=https://api.mor.org/api/v1
MORPHEUS_API_KEY=
MORPHEUS_PARSE_MODEL=llama-3.3-70b
# Agent tool-calling mode: auto | native | react (native is most reliable here)
MORPHEUS_AGENT_TOOLS=native

# Reconciliation lookback window (days)
RECON_LOOKBACK_DAYS=365

# Tesseract: LEAVE UNSET on Linux/Docker — the binary is on PATH (see Dockerfile).
# Only set this to tesseract.exe's full path on a Windows host.
# TESSERACT_CMD=

# USE_AGENT defaults to true (agentic engine). Set to false to force the legacy
# linear pipeline. Optional; omit to use the default.
# USE_AGENT=true

# MyInvois (LHDN e-Invoice): NO env keys. Credentials are per-tenant, stored in the
# myinvois_credential table (taxpayer client_id/secret/TIN + environment) and entered
# via the frontend Settings page. environment='mock' needs no real creds.

# Finverse bank feed (open banking). App creds are GLOBAL (one developer app), not
# per-tenant. FINVERSE_ENV=mock needs no creds and demos the full consent→sync→recon
# path offline. For sandbox/prod: rotate the client secret in dashboard.finverse.com,
# register FINVERSE_REDIRECT_URI there, then set the values below and restart.
FINVERSE_ENV=mock                       # mock | sandbox | prod
FINVERSE_CLIENT_ID=
FINVERSE_CLIENT_SECRET=                  # SECRET (fv-c-…). Rotate before use — never commit.
FINVERSE_REDIRECT_URI=http://127.0.0.1:8000/api/bankfeed/callback  # must be whitelisted in the dashboard
# Where the callback 302s the user back to (the Next.js app).
FRONTEND_URL=http://localhost:3000
# HMAC secret that signs the OAuth `state` (tenant routing + CSRF across the redirect).
# Use a long random value in real environments.
BANKFEED_STATE_SECRET=
