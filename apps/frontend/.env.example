# Frontend env contract. These are PUBLIC (baked into the client bundle at build
# time) — only ever the anon key here, never the service_role key.
# On Vercel: set these in Project Settings → Environment Variables, then build.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Full https URL of the deployed backend (no trailing slash), e.g.
# https://treasuryflow-api.onrender.com
NEXT_PUBLIC_API_URL=
